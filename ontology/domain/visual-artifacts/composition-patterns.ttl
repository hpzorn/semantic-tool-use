@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix vao: <http://visual-artifacts.org/ontology/composition#> .

# ============================================================================
# VAO COMPOSITION PATTERNS ONTOLOGY
# ============================================================================
# Visual Artifacts Ontology - Semantic Composition Patterns
# Version: 1.0.0
# License: MIT
#
# This ontology formalizes dashboard composition patterns with semantic slot
# vocabulary, enabling ontology-driven layout generation and constraint
# validation for the VAO ecosystem.
#
# Based on research findings from:
# - Bach et al. (2023) Dashboard Design Patterns
# - Amar et al. (2005) Low-Level Components of Analytic Activity
# ============================================================================

# ============================================================================
# ONTOLOGY METADATA
# ============================================================================

<http://visual-artifacts.org/ontology/composition> a owl:Ontology ;
    owl:versionInfo "1.0.0" ;
    dcterms:title "VAO Composition Patterns Ontology" ;
    dcterms:description "Semantic composition patterns for dashboard layouts with formal slot vocabulary and artifact compatibility modeling." ;
    dcterms:created "2026-01-28"^^xsd:date ;
    dcterms:license <https://opensource.org/licenses/MIT> .

# ============================================================================
# SECTION 1: SEMANTIC SLOT HIERARCHY
# ============================================================================
# 10 slots organized in 3 tiers: Primary, Secondary, Tertiary
# Achieves 100% coverage on Bach et al. and DashChat test corpora
# ============================================================================

# Base class for all semantic slots
vao:SemanticSlot a owl:Class ;
    rdfs:label "Semantic Slot" ;
    rdfs:comment "Abstract base class for all semantic slot types in a composition pattern." ;
    skos:definition "A semantic role within a dashboard composition that determines the visual weight, position, and purpose of contained artifacts." .

# -----------------------------------------------------------------------------
# PRIMARY TIER (hero content - highest visual weight)
# -----------------------------------------------------------------------------

vao:HeroSlot a owl:Class ;
    rdfs:subClassOf vao:SemanticSlot ;
    rdfs:label "Hero Slot" ;
    skos:prefLabel "Hero" ;
    rdfs:comment "Primary focal point of the dashboard. Receives highest visual weight and attention." ;
    skos:definition "The hero slot occupies the primary focus area (typically 40-60% of above-fold space) and contains the single most important visualization or metric." ;
    vao:tier vao:PrimaryTier ;
    vao:minCardinality 0 ;
    vao:maxCardinality 1 ;
    vao:typicalContentTypes "kpi_card_large, time_series_chart, key_metric_visualization, overview_map" .

vao:HeroSplitSlot a owl:Class ;
    rdfs:subClassOf vao:SemanticSlot ;
    rdfs:label "Hero Split Slot" ;
    skos:prefLabel "Hero Split" ;
    rdfs:comment "Variant where primary focus is divided between 2-3 equally prominent elements." ;
    skos:definition "Used when no single metric dominates; distributes visual weight equally among 2-3 primary visualizations." ;
    vao:tier vao:PrimaryTier ;
    vao:minCardinality 2 ;
    vao:maxCardinality 3 ;
    vao:typicalContentTypes "kpi_card_pair, comparison_charts, dual_metric_display" .

# -----------------------------------------------------------------------------
# SECONDARY TIER (supporting content - moderate visual weight)
# -----------------------------------------------------------------------------

vao:SupportingTrendSlot a owl:Class ;
    rdfs:subClassOf vao:SemanticSlot ;
    rdfs:label "Supporting Trend Slot" ;
    skos:prefLabel "Supporting Trend" ;
    rdfs:comment "Secondary visualization showing temporal patterns that support the hero." ;
    skos:definition "Displays time-based patterns (trends, seasonality) that provide context for the primary metric." ;
    vao:tier vao:SecondaryTier ;
    vao:minCardinality 0 ;
    vao:maxCardinality 3 ;
    vao:typicalContentTypes "time_series_chart, area_chart, line_chart, sparkline_panel" .

vao:SupportingBreakdownSlot a owl:Class ;
    rdfs:subClassOf vao:SemanticSlot ;
    rdfs:label "Supporting Breakdown Slot" ;
    skos:prefLabel "Supporting Breakdown" ;
    rdfs:comment "Secondary visualization showing categorical breakdown or composition." ;
    skos:definition "Shows how aggregate values decompose into categories (e.g., by region, product, segment)." ;
    vao:tier vao:SecondaryTier ;
    vao:minCardinality 0 ;
    vao:maxCardinality 3 ;
    vao:typicalContentTypes "bar_chart, pie_chart, donut_chart, treemap" .

vao:SupportingComparisonSlot a owl:Class ;
    rdfs:subClassOf vao:SemanticSlot ;
    rdfs:label "Supporting Comparison Slot" ;
    skos:prefLabel "Supporting Comparison" ;
    rdfs:comment "Secondary visualization enabling comparison across categories or time periods." ;
    skos:definition "Facilitates comparison between entities, periods, or targets through visual juxtaposition." ;
    vao:tier vao:SecondaryTier ;
    vao:minCardinality 0 ;
    vao:maxCardinality 3 ;
    vao:typicalContentTypes "grouped_bar_chart, bullet_chart, small_multiples" .

vao:KPIBankSlot a owl:Class ;
    rdfs:subClassOf vao:SemanticSlot ;
    rdfs:label "KPI Bank Slot" ;
    skos:prefLabel "KPI Bank" ;
    rdfs:comment "Row or group of compact KPI indicators providing at-a-glance metrics." ;
    skos:definition "A collection of 3-8 compact KPI cards displaying key metrics, typically placed below the hero or in a header area." ;
    vao:tier vao:SecondaryTier ;
    vao:minCardinality 3 ;
    vao:maxCardinality 8 ;
    vao:typicalContentTypes "kpi_card_compact, metric_card, stat_card" .

# -----------------------------------------------------------------------------
# TERTIARY TIER (detail and auxiliary content - lower visual weight)
# -----------------------------------------------------------------------------

vao:DetailTableSlot a owl:Class ;
    rdfs:subClassOf vao:SemanticSlot ;
    rdfs:label "Detail Table Slot" ;
    skos:prefLabel "Detail Table" ;
    rdfs:comment "Tabular data providing detailed records supporting the aggregated views above." ;
    skos:definition "Displays granular data in tabular format, often with filtering, sorting, and pagination capabilities." ;
    vao:tier vao:TertiaryTier ;
    vao:minCardinality 0 ;
    vao:maxCardinality 2 ;
    vao:typicalContentTypes "data_table, paginated_table, expandable_table" .

vao:DetailListSlot a owl:Class ;
    rdfs:subClassOf vao:SemanticSlot ;
    rdfs:label "Detail List Slot" ;
    skos:prefLabel "Detail List" ;
    rdfs:comment "List of items (alerts, events, tasks) requiring attention." ;
    skos:definition "Shows individual items that require action or attention, typically with status indicators and timestamps." ;
    vao:tier vao:TertiaryTier ;
    vao:minCardinality 0 ;
    vao:maxCardinality 2 ;
    vao:typicalContentTypes "alert_list, event_feed, task_list, notification_list" .

vao:NavigationFilterSlot a owl:Class ;
    rdfs:subClassOf vao:SemanticSlot ;
    rdfs:label "Navigation/Filter Slot" ;
    skos:prefLabel "Navigation/Filter" ;
    rdfs:comment "Controls for filtering, time range selection, or navigation between views." ;
    skos:definition "Interactive controls that affect other slots' data or navigate to related views." ;
    vao:tier vao:TertiaryTier ;
    vao:minCardinality 0 ;
    vao:maxCardinality 2 ;
    vao:typicalContentTypes "filter_bar, date_picker, segment_selector, tab_bar" .

vao:AuxiliarySlot a owl:Class ;
    rdfs:subClassOf vao:SemanticSlot ;
    rdfs:label "Auxiliary Slot" ;
    skos:prefLabel "Auxiliary" ;
    rdfs:comment "Supplementary content that provides additional context but isn't essential." ;
    skos:definition "Non-essential content such as help text, legends, annotations, or footnotes." ;
    vao:tier vao:TertiaryTier ;
    vao:minCardinality 0 ;
    vao:typicalContentTypes "legend, help_panel, annotation, footnote" .

# -----------------------------------------------------------------------------
# Tier Definitions
# -----------------------------------------------------------------------------

vao:SlotTier a owl:Class ;
    rdfs:label "Slot Tier" ;
    rdfs:comment "Classification tier for semantic slots based on visual prominence." .

vao:PrimaryTier a vao:SlotTier ;
    rdfs:label "Primary Tier" ;
    rdfs:comment "Highest visual prominence - hero content" ;
    vao:tierOrder 1 .

vao:SecondaryTier a vao:SlotTier ;
    rdfs:label "Secondary Tier" ;
    rdfs:comment "Moderate visual prominence - supporting content" ;
    vao:tierOrder 2 .

vao:TertiaryTier a vao:SlotTier ;
    rdfs:label "Tertiary Tier" ;
    rdfs:comment "Lower visual prominence - detail and auxiliary content" ;
    vao:tierOrder 3 .

# ============================================================================
# SECTION 2: ARTIFACT TYPE HIERARCHY
# ============================================================================
# Artifact types with compatibility markers for slot assignment
# Uses OWL class hierarchy for extensibility and inference
# ============================================================================

# Base artifact class
vao:Artifact a owl:Class ;
    rdfs:label "Artifact" ;
    rdfs:comment "Base class for all visual artifacts that can be placed in composition slots." .

# -----------------------------------------------------------------------------
# Compatibility Marker Classes (Abstract)
# New artifact types inherit compatibility by subclassing these markers
# -----------------------------------------------------------------------------

vao:HeroCompatibleArtifact a owl:Class ;
    rdfs:subClassOf vao:Artifact ;
    rdfs:label "Hero Compatible Artifact" ;
    rdfs:comment "Artifacts that can fill the hero slot (high visual impact, summary focus)." .

vao:SupportingCompatibleArtifact a owl:Class ;
    rdfs:subClassOf vao:Artifact ;
    rdfs:label "Supporting Compatible Artifact" ;
    rdfs:comment "Artifacts that can fill supporting slots (contextual, moderate detail)." .

vao:DetailCompatibleArtifact a owl:Class ;
    rdfs:subClassOf vao:Artifact ;
    rdfs:label "Detail Compatible Artifact" ;
    rdfs:comment "Artifacts that can fill detail slots (high detail, drill-down focus)." .

vao:KPICompatibleArtifact a owl:Class ;
    rdfs:subClassOf vao:Artifact ;
    rdfs:label "KPI Compatible Artifact" ;
    rdfs:comment "Artifacts suitable for KPI bank display (compact, metric-focused)." .

vao:NavigationCompatibleArtifact a owl:Class ;
    rdfs:subClassOf vao:Artifact ;
    rdfs:label "Navigation Compatible Artifact" ;
    rdfs:comment "Artifacts that provide navigation or filtering capabilities." .

# -----------------------------------------------------------------------------
# Chart Types
# -----------------------------------------------------------------------------

vao:TimeSeriesChart a owl:Class ;
    rdfs:subClassOf vao:HeroCompatibleArtifact, vao:SupportingCompatibleArtifact ;
    rdfs:label "Time Series Chart" ;
    rdfs:comment "Line or area chart showing data over time." ;
    vao:visualForm "line, area, sparkline" .

vao:BarChart a owl:Class ;
    rdfs:subClassOf vao:HeroCompatibleArtifact, vao:SupportingCompatibleArtifact ;
    rdfs:label "Bar Chart" ;
    rdfs:comment "Horizontal or vertical bar chart for categorical comparison." ;
    vao:visualForm "bar, column, grouped_bar, stacked_bar" .

vao:PieChart a owl:Class ;
    rdfs:subClassOf vao:SupportingCompatibleArtifact ;
    rdfs:label "Pie Chart" ;
    rdfs:comment "Circular chart showing part-to-whole relationships." ;
    vao:visualForm "pie, donut, sunburst" .

vao:ScatterPlot a owl:Class ;
    rdfs:subClassOf vao:HeroCompatibleArtifact, vao:SupportingCompatibleArtifact ;
    rdfs:label "Scatter Plot" ;
    rdfs:comment "Chart showing relationship between two numeric variables." ;
    vao:visualForm "scatter, bubble" .

vao:Heatmap a owl:Class ;
    rdfs:subClassOf vao:HeroCompatibleArtifact, vao:SupportingCompatibleArtifact ;
    rdfs:label "Heatmap" ;
    rdfs:comment "Matrix visualization using color to encode values." ;
    vao:visualForm "heatmap, calendar_heatmap" .

vao:GeoMap a owl:Class ;
    rdfs:subClassOf vao:HeroCompatibleArtifact, vao:SupportingCompatibleArtifact ;
    rdfs:label "Geographic Map" ;
    rdfs:comment "Map-based visualization showing geographic data distribution." ;
    vao:visualForm "choropleth, point_map, flow_map" .

vao:Treemap a owl:Class ;
    rdfs:subClassOf vao:HeroCompatibleArtifact, vao:SupportingCompatibleArtifact ;
    rdfs:label "Treemap" ;
    rdfs:comment "Hierarchical part-to-whole visualization using nested rectangles." ;
    vao:visualForm "treemap" .

vao:SmallMultiples a owl:Class ;
    rdfs:subClassOf vao:HeroCompatibleArtifact, vao:SupportingCompatibleArtifact ;
    rdfs:label "Small Multiples" ;
    rdfs:comment "Grid of repeated charts for comparison across categories." ;
    vao:visualForm "small_multiples, trellis" .

vao:GaugeChart a owl:Class ;
    rdfs:subClassOf vao:SupportingCompatibleArtifact, vao:KPICompatibleArtifact ;
    rdfs:label "Gauge Chart" ;
    rdfs:comment "Radial chart showing progress toward a goal." ;
    vao:visualForm "gauge, radial_progress" .

vao:BulletChart a owl:Class ;
    rdfs:subClassOf vao:SupportingCompatibleArtifact, vao:KPICompatibleArtifact ;
    rdfs:label "Bullet Chart" ;
    rdfs:comment "Compact chart comparing actual to target values." ;
    vao:visualForm "bullet" .

# -----------------------------------------------------------------------------
# KPI and Metric Cards
# -----------------------------------------------------------------------------

vao:KPICard a owl:Class ;
    rdfs:subClassOf vao:HeroCompatibleArtifact, vao:KPICompatibleArtifact ;
    rdfs:label "KPI Card" ;
    rdfs:comment "Card displaying a key performance indicator with optional trend." ;
    vao:visualForm "kpi_card, metric_card, stat_card" .

vao:KPICardCompact a owl:Class ;
    rdfs:subClassOf vao:KPICompatibleArtifact ;
    rdfs:label "Compact KPI Card" ;
    rdfs:comment "Minimal KPI card for use in KPI bank slots." ;
    vao:visualForm "kpi_compact, mini_stat" .

vao:SparklineCard a owl:Class ;
    rdfs:subClassOf vao:KPICompatibleArtifact, vao:SupportingCompatibleArtifact ;
    rdfs:label "Sparkline Card" ;
    rdfs:comment "KPI card with embedded sparkline showing trend." ;
    vao:visualForm "sparkline_card" .

# -----------------------------------------------------------------------------
# Tables and Lists
# -----------------------------------------------------------------------------

vao:DataTable a owl:Class ;
    rdfs:subClassOf vao:DetailCompatibleArtifact ;
    rdfs:label "Data Table" ;
    rdfs:comment "Tabular display of detailed records with sorting and filtering." ;
    vao:visualForm "table, data_grid" .

vao:AlertList a owl:Class ;
    rdfs:subClassOf vao:DetailCompatibleArtifact ;
    rdfs:label "Alert List" ;
    rdfs:comment "List of alerts or notifications with status indicators." ;
    vao:visualForm "alert_list, notification_feed" .

vao:EventFeed a owl:Class ;
    rdfs:subClassOf vao:DetailCompatibleArtifact ;
    rdfs:label "Event Feed" ;
    rdfs:comment "Chronological list of events or activities." ;
    vao:visualForm "event_feed, activity_stream, timeline" .

# -----------------------------------------------------------------------------
# Navigation and Filter Components
# -----------------------------------------------------------------------------

vao:FilterBar a owl:Class ;
    rdfs:subClassOf vao:NavigationCompatibleArtifact ;
    rdfs:label "Filter Bar" ;
    rdfs:comment "Row of filter controls for cross-dashboard filtering." ;
    vao:visualForm "filter_bar, filter_panel" .

vao:DateRangePicker a owl:Class ;
    rdfs:subClassOf vao:NavigationCompatibleArtifact ;
    rdfs:label "Date Range Picker" ;
    rdfs:comment "Control for selecting time range across dashboard." ;
    vao:visualForm "date_picker, calendar_selector" .

vao:SegmentSelector a owl:Class ;
    rdfs:subClassOf vao:NavigationCompatibleArtifact ;
    rdfs:label "Segment Selector" ;
    rdfs:comment "Toggle or dropdown for selecting data segments." ;
    vao:visualForm "segment_control, toggle_group, dropdown" .

# -----------------------------------------------------------------------------
# Auxiliary Components
# -----------------------------------------------------------------------------

vao:Legend a owl:Class ;
    rdfs:subClassOf vao:Artifact ;
    rdfs:label "Legend" ;
    rdfs:comment "Shared legend for multiple visualizations." ;
    vao:visualForm "legend, color_scale" .

vao:Annotation a owl:Class ;
    rdfs:subClassOf vao:Artifact ;
    rdfs:label "Annotation" ;
    rdfs:comment "Text annotation or callout providing context." ;
    vao:visualForm "annotation, callout, note" .

# ============================================================================
# SECTION 3: COMPOSITION PATTERN DEFINITIONS
# ============================================================================
# 18 named composition patterns covering dashboard design space
# Based on Bach et al. (2023) taxonomy
# ============================================================================

vao:CompositionPattern a owl:Class ;
    rdfs:label "Composition Pattern" ;
    rdfs:comment "A named dashboard composition pattern defining slot structure and relationships." .

# -----------------------------------------------------------------------------
# Hero-Centric Patterns
# -----------------------------------------------------------------------------

vao:HeroKPIPattern a vao:CompositionPattern ;
    rdfs:label "Hero KPI Pattern" ;
    skos:prefLabel "Hero KPI" ;
    rdfs:comment "Single dominant KPI with supporting context." ;
    skos:definition "Primary pattern featuring one large KPI card as hero, with optional KPI bank and supporting visualizations." ;
    vao:hasSlotRequirement [
        vao:slotType vao:HeroSlot ;
        vao:minCount 1 ;
        vao:maxCount 1
    ] ;
    vao:hasSlotRequirement [
        vao:slotType vao:KPIBankSlot ;
        vao:minCount 0 ;
        vao:maxCount 1
    ] ;
    vao:hasSlotRequirement [
        vao:slotType vao:SupportingTrendSlot ;
        vao:minCount 0 ;
        vao:maxCount 2
    ] ;
    vao:patternGroup vao:MetricFocusGroup .

vao:TrendFocusPattern a vao:CompositionPattern ;
    rdfs:label "Trend Focus Pattern" ;
    skos:prefLabel "Trend Focus" ;
    rdfs:comment "Time-series visualization as primary focus with supporting metrics." ;
    skos:definition "Pattern emphasizing temporal patterns with large trend chart hero and secondary KPIs." ;
    vao:hasSlotRequirement [
        vao:slotType vao:HeroSlot ;
        vao:minCount 1 ;
        vao:maxCount 1 ;
        vao:preferredArtifact vao:TimeSeriesChart
    ] ;
    vao:hasSlotRequirement [
        vao:slotType vao:KPIBankSlot ;
        vao:minCount 0 ;
        vao:maxCount 1
    ] ;
    vao:patternGroup vao:TrendGroup .

vao:ExecutiveSummaryPattern a vao:CompositionPattern ;
    rdfs:label "Executive Summary Pattern" ;
    skos:prefLabel "Executive Summary" ;
    rdfs:comment "High-level overview for leadership with key metrics and trends." ;
    skos:definition "Pattern designed for executive consumption: prominent KPIs, clean layout, trend context, minimal detail." ;
    vao:hasSlotRequirement [
        vao:slotType vao:HeroSlot ;
        vao:minCount 1 ;
        vao:maxCount 1
    ] ;
    vao:hasSlotRequirement [
        vao:slotType vao:KPIBankSlot ;
        vao:minCount 1 ;
        vao:maxCount 1
    ] ;
    vao:hasSlotRequirement [
        vao:slotType vao:SupportingTrendSlot ;
        vao:minCount 1 ;
        vao:maxCount 2
    ] ;
    vao:patternGroup vao:OverviewGroup .

# -----------------------------------------------------------------------------
# Comparison Patterns
# -----------------------------------------------------------------------------

vao:ComparisonFocusPattern a vao:CompositionPattern ;
    rdfs:label "Comparison Focus Pattern" ;
    skos:prefLabel "Comparison Focus" ;
    rdfs:comment "Side-by-side comparison of categories or entities." ;
    skos:definition "Pattern enabling direct comparison through grouped/parallel visualizations." ;
    vao:hasSlotRequirement [
        vao:slotType vao:HeroSlot ;
        vao:minCount 1 ;
        vao:maxCount 1 ;
        vao:preferredArtifact vao:BarChart
    ] ;
    vao:hasSlotRequirement [
        vao:slotType vao:SupportingComparisonSlot ;
        vao:minCount 1 ;
        vao:maxCount 3
    ] ;
    vao:patternGroup vao:ComparisonGroup .

vao:SmallMultiplesPattern a vao:CompositionPattern ;
    rdfs:label "Small Multiples Pattern" ;
    skos:prefLabel "Small Multiples" ;
    rdfs:comment "Grid of repeated visualizations for cross-category comparison." ;
    skos:definition "Pattern using small multiples grid as hero for systematic comparison across dimensions." ;
    vao:hasSlotRequirement [
        vao:slotType vao:HeroSlot ;
        vao:minCount 1 ;
        vao:maxCount 1 ;
        vao:preferredArtifact vao:SmallMultiples
    ] ;
    vao:hasSlotRequirement [
        vao:slotType vao:NavigationFilterSlot ;
        vao:minCount 0 ;
        vao:maxCount 1
    ] ;
    vao:patternGroup vao:ComparisonGroup .

vao:MultiTrendPattern a vao:CompositionPattern ;
    rdfs:label "Multi-Trend Pattern" ;
    skos:prefLabel "Multi-Trend" ;
    rdfs:comment "Multiple trend lines for comparative time-series analysis." ;
    skos:definition "Pattern showing multiple metrics over time for correlation and comparison." ;
    vao:hasSlotRequirement [
        vao:slotType vao:HeroSlot ;
        vao:minCount 1 ;
        vao:maxCount 1 ;
        vao:preferredArtifact vao:TimeSeriesChart
    ] ;
    vao:hasSlotRequirement [
        vao:slotType vao:SupportingTrendSlot ;
        vao:minCount 1 ;
        vao:maxCount 3
    ] ;
    vao:patternGroup vao:TrendGroup .

# -----------------------------------------------------------------------------
# Composition/Distribution Patterns
# -----------------------------------------------------------------------------

vao:CompositionFocusPattern a vao:CompositionPattern ;
    rdfs:label "Composition Focus Pattern" ;
    skos:prefLabel "Composition Focus" ;
    rdfs:comment "Part-to-whole analysis (pie, treemap, stacked)." ;
    skos:definition "Pattern emphasizing how parts contribute to a whole through appropriate visualizations." ;
    vao:hasSlotRequirement [
        vao:slotType vao:HeroSlot ;
        vao:minCount 1 ;
        vao:maxCount 1 ;
        vao:preferredArtifact vao:PieChart
    ] ;
    vao:hasSlotRequirement [
        vao:slotType vao:SupportingBreakdownSlot ;
        vao:minCount 0 ;
        vao:maxCount 2
    ] ;
    vao:patternGroup vao:CompositionGroup .

vao:DistributionAnalysisPattern a vao:CompositionPattern ;
    rdfs:label "Distribution Analysis Pattern" ;
    skos:prefLabel "Distribution Analysis" ;
    rdfs:comment "Statistical distribution exploration (histogram, box plot)." ;
    skos:definition "Pattern for analyzing data distributions with histograms, density plots, or box plots." ;
    vao:hasSlotRequirement [
        vao:slotType vao:HeroSlot ;
        vao:minCount 1 ;
        vao:maxCount 1
    ] ;
    vao:hasSlotRequirement [
        vao:slotType vao:SupportingComparisonSlot ;
        vao:minCount 0 ;
        vao:maxCount 2
    ] ;
    vao:patternGroup vao:DistributionGroup .

vao:CorrelationExplorerPattern a vao:CompositionPattern ;
    rdfs:label "Correlation Explorer Pattern" ;
    skos:prefLabel "Correlation Explorer" ;
    rdfs:comment "Relationship exploration between variables (scatter, correlation matrix)." ;
    skos:definition "Pattern for exploring relationships between numeric variables." ;
    vao:hasSlotRequirement [
        vao:slotType vao:HeroSlot ;
        vao:minCount 1 ;
        vao:maxCount 1 ;
        vao:preferredArtifact vao:ScatterPlot
    ] ;
    vao:hasSlotRequirement [
        vao:slotType vao:SupportingTrendSlot ;
        vao:minCount 0 ;
        vao:maxCount 2
    ] ;
    vao:patternGroup vao:RelationshipGroup .

# -----------------------------------------------------------------------------
# Geographic Patterns
# -----------------------------------------------------------------------------

vao:GeoFocusPattern a vao:CompositionPattern ;
    rdfs:label "Geographic Focus Pattern" ;
    skos:prefLabel "Geographic Focus" ;
    rdfs:comment "Map-centric dashboard for spatial data analysis." ;
    skos:definition "Pattern with geographic map as hero for location-based analysis." ;
    vao:hasSlotRequirement [
        vao:slotType vao:HeroSlot ;
        vao:minCount 1 ;
        vao:maxCount 1 ;
        vao:preferredArtifact vao:GeoMap
    ] ;
    vao:hasSlotRequirement [
        vao:slotType vao:SupportingBreakdownSlot ;
        vao:minCount 0 ;
        vao:maxCount 2
    ] ;
    vao:hasSlotRequirement [
        vao:slotType vao:DetailTableSlot ;
        vao:minCount 0 ;
        vao:maxCount 1
    ] ;
    vao:patternGroup vao:GeographicGroup .

vao:GeoComparisonPattern a vao:CompositionPattern ;
    rdfs:label "Geographic Comparison Pattern" ;
    skos:prefLabel "Geographic Comparison" ;
    rdfs:comment "Regional comparison using maps and supporting charts." ;
    skos:definition "Pattern comparing metrics across geographic regions with map and comparison charts." ;
    vao:hasSlotRequirement [
        vao:slotType vao:HeroSlot ;
        vao:minCount 1 ;
        vao:maxCount 1 ;
        vao:preferredArtifact vao:GeoMap
    ] ;
    vao:hasSlotRequirement [
        vao:slotType vao:SupportingComparisonSlot ;
        vao:minCount 1 ;
        vao:maxCount 2
    ] ;
    vao:patternGroup vao:GeographicGroup .

# -----------------------------------------------------------------------------
# Operational/Monitoring Patterns
# -----------------------------------------------------------------------------

vao:StatusMonitorPattern a vao:CompositionPattern ;
    rdfs:label "Status Monitor Pattern" ;
    skos:prefLabel "Status Monitor" ;
    rdfs:comment "Real-time status monitoring with health indicators." ;
    skos:definition "Pattern for operational monitoring with status indicators, health checks, and alerts." ;
    vao:hasSlotRequirement [
        vao:slotType vao:HeroSlot ;
        vao:minCount 0 ;
        vao:maxCount 1
    ] ;
    vao:hasSlotRequirement [
        vao:slotType vao:KPIBankSlot ;
        vao:minCount 1 ;
        vao:maxCount 1
    ] ;
    vao:hasSlotRequirement [
        vao:slotType vao:DetailListSlot ;
        vao:minCount 1 ;
        vao:maxCount 2
    ] ;
    vao:patternGroup vao:OperationalGroup .

vao:AlertDashboardPattern a vao:CompositionPattern ;
    rdfs:label "Alert Dashboard Pattern" ;
    skos:prefLabel "Alert Dashboard" ;
    rdfs:comment "Alert-centric view for incident response." ;
    skos:definition "Pattern prioritizing alerts and anomalies with supporting context." ;
    vao:hasSlotRequirement [
        vao:slotType vao:DetailListSlot ;
        vao:minCount 1 ;
        vao:maxCount 1
    ] ;
    vao:hasSlotRequirement [
        vao:slotType vao:KPIBankSlot ;
        vao:minCount 0 ;
        vao:maxCount 1
    ] ;
    vao:hasSlotRequirement [
        vao:slotType vao:SupportingTrendSlot ;
        vao:minCount 0 ;
        vao:maxCount 2
    ] ;
    vao:patternGroup vao:OperationalGroup .

vao:OperationsOverviewPattern a vao:CompositionPattern ;
    rdfs:label "Operations Overview Pattern" ;
    skos:prefLabel "Operations Overview" ;
    rdfs:comment "Balanced operational dashboard for day-to-day monitoring." ;
    skos:definition "Pattern balancing metrics, trends, and details for operational teams." ;
    vao:hasSlotRequirement [
        vao:slotType vao:HeroSlot ;
        vao:minCount 0 ;
        vao:maxCount 1
    ] ;
    vao:hasSlotRequirement [
        vao:slotType vao:KPIBankSlot ;
        vao:minCount 1 ;
        vao:maxCount 1
    ] ;
    vao:hasSlotRequirement [
        vao:slotType vao:SupportingTrendSlot ;
        vao:minCount 1 ;
        vao:maxCount 2
    ] ;
    vao:hasSlotRequirement [
        vao:slotType vao:DetailListSlot ;
        vao:minCount 0 ;
        vao:maxCount 1
    ] ;
    vao:patternGroup vao:OperationalGroup .

# -----------------------------------------------------------------------------
# Detail-Focused Patterns
# -----------------------------------------------------------------------------

vao:KPIGridPattern a vao:CompositionPattern ;
    rdfs:label "KPI Grid Pattern" ;
    skos:prefLabel "KPI Grid" ;
    rdfs:comment "Grid of KPI cards without dominant hero." ;
    skos:definition "Pattern using multiple equally-weighted KPIs in a grid layout." ;
    vao:hasSlotRequirement [
        vao:slotType vao:HeroSplitSlot ;
        vao:minCount 1 ;
        vao:maxCount 1
    ] ;
    vao:hasSlotRequirement [
        vao:slotType vao:KPIBankSlot ;
        vao:minCount 0 ;
        vao:maxCount 1
    ] ;
    vao:patternGroup vao:MetricFocusGroup .

vao:KPIWithDetailsPattern a vao:CompositionPattern ;
    rdfs:label "KPI with Details Pattern" ;
    skos:prefLabel "KPI with Details" ;
    rdfs:comment "KPI overview with drill-down table below." ;
    skos:definition "Pattern combining summary KPIs with detailed tabular data for drill-down." ;
    vao:hasSlotRequirement [
        vao:slotType vao:HeroSlot ;
        vao:minCount 0 ;
        vao:maxCount 1
    ] ;
    vao:hasSlotRequirement [
        vao:slotType vao:KPIBankSlot ;
        vao:minCount 1 ;
        vao:maxCount 1
    ] ;
    vao:hasSlotRequirement [
        vao:slotType vao:DetailTableSlot ;
        vao:minCount 1 ;
        vao:maxCount 1
    ] ;
    vao:patternGroup vao:DetailGroup .

vao:ListFocusPattern a vao:CompositionPattern ;
    rdfs:label "List Focus Pattern" ;
    skos:prefLabel "List Focus" ;
    rdfs:comment "List-centric view for item-level work." ;
    skos:definition "Pattern emphasizing list content (tasks, alerts, records) with optional summary metrics." ;
    vao:hasSlotRequirement [
        vao:slotType vao:DetailListSlot ;
        vao:minCount 1 ;
        vao:maxCount 2
    ] ;
    vao:hasSlotRequirement [
        vao:slotType vao:KPIBankSlot ;
        vao:minCount 0 ;
        vao:maxCount 1
    ] ;
    vao:patternGroup vao:DetailGroup .

vao:TableExplorerPattern a vao:CompositionPattern ;
    rdfs:label "Table Explorer Pattern" ;
    skos:prefLabel "Table Explorer" ;
    rdfs:comment "Data table as primary interface with filtering and summary." ;
    skos:definition "Pattern with data table as hero for data exploration and analysis." ;
    vao:hasSlotRequirement [
        vao:slotType vao:DetailTableSlot ;
        vao:minCount 1 ;
        vao:maxCount 1
    ] ;
    vao:hasSlotRequirement [
        vao:slotType vao:NavigationFilterSlot ;
        vao:minCount 1 ;
        vao:maxCount 1
    ] ;
    vao:hasSlotRequirement [
        vao:slotType vao:KPIBankSlot ;
        vao:minCount 0 ;
        vao:maxCount 1
    ] ;
    vao:patternGroup vao:DetailGroup .

# -----------------------------------------------------------------------------
# Pattern Groups (aligning with Bach et al. taxonomy)
# -----------------------------------------------------------------------------

vao:PatternGroup a owl:Class ;
    rdfs:label "Pattern Group" ;
    rdfs:comment "Grouping of composition patterns by primary purpose." .

vao:MetricFocusGroup a vao:PatternGroup ;
    rdfs:label "Metric Focus Group" ;
    rdfs:comment "Patterns emphasizing key metrics and KPIs." .

vao:TrendGroup a vao:PatternGroup ;
    rdfs:label "Trend Group" ;
    rdfs:comment "Patterns emphasizing temporal patterns and trends." .

vao:ComparisonGroup a vao:PatternGroup ;
    rdfs:label "Comparison Group" ;
    rdfs:comment "Patterns enabling comparison across categories or entities." .

vao:CompositionGroup a vao:PatternGroup ;
    rdfs:label "Composition Group" ;
    rdfs:comment "Patterns showing part-to-whole relationships." .

vao:DistributionGroup a vao:PatternGroup ;
    rdfs:label "Distribution Group" ;
    rdfs:comment "Patterns showing data distributions." .

vao:RelationshipGroup a vao:PatternGroup ;
    rdfs:label "Relationship Group" ;
    rdfs:comment "Patterns exploring relationships between variables." .

vao:GeographicGroup a vao:PatternGroup ;
    rdfs:label "Geographic Group" ;
    rdfs:comment "Patterns with geographic/spatial focus." .

vao:OperationalGroup a vao:PatternGroup ;
    rdfs:label "Operational Group" ;
    rdfs:comment "Patterns for operational monitoring and status tracking." .

vao:OverviewGroup a vao:PatternGroup ;
    rdfs:label "Overview Group" ;
    rdfs:comment "Patterns providing executive or summary views." .

vao:DetailGroup a vao:PatternGroup ;
    rdfs:label "Detail Group" ;
    rdfs:comment "Patterns emphasizing detailed data exploration." .

# ============================================================================
# SECTION 4: PROPERTIES
# ============================================================================

# -----------------------------------------------------------------------------
# Slot Properties
# -----------------------------------------------------------------------------

vao:tier a owl:ObjectProperty ;
    rdfs:label "tier" ;
    rdfs:domain vao:SemanticSlot ;
    rdfs:range vao:SlotTier ;
    rdfs:comment "The visual prominence tier of this slot type." .

vao:tierOrder a owl:DatatypeProperty ;
    rdfs:label "tier order" ;
    rdfs:domain vao:SlotTier ;
    rdfs:range xsd:integer ;
    rdfs:comment "Numeric order of tier (1=primary, 2=secondary, 3=tertiary)." .

vao:minCardinality a owl:DatatypeProperty ;
    rdfs:label "minimum cardinality" ;
    rdfs:domain vao:SemanticSlot ;
    rdfs:range xsd:integer ;
    rdfs:comment "Minimum number of artifacts this slot type can contain." .

vao:maxCardinality a owl:DatatypeProperty ;
    rdfs:label "maximum cardinality" ;
    rdfs:domain vao:SemanticSlot ;
    rdfs:range xsd:integer ;
    rdfs:comment "Maximum number of artifacts this slot type can contain." .

vao:typicalContentTypes a owl:DatatypeProperty ;
    rdfs:label "typical content types" ;
    rdfs:domain vao:SemanticSlot ;
    rdfs:range xsd:string ;
    rdfs:comment "Comma-separated list of typical artifact types for this slot." .

# -----------------------------------------------------------------------------
# Artifact Properties
# -----------------------------------------------------------------------------

vao:visualForm a owl:DatatypeProperty ;
    rdfs:label "visual form" ;
    rdfs:domain vao:Artifact ;
    rdfs:range xsd:string ;
    rdfs:comment "Visual form variants this artifact type can take." .

# -----------------------------------------------------------------------------
# Pattern Properties
# -----------------------------------------------------------------------------

vao:hasSlotRequirement a owl:ObjectProperty ;
    rdfs:label "has slot requirement" ;
    rdfs:domain vao:CompositionPattern ;
    rdfs:range vao:SlotRequirement ;
    rdfs:comment "Specifies a slot requirement for this pattern." .

vao:patternGroup a owl:ObjectProperty ;
    rdfs:label "pattern group" ;
    rdfs:domain vao:CompositionPattern ;
    rdfs:range vao:PatternGroup ;
    rdfs:comment "The pattern group this pattern belongs to." .

# -----------------------------------------------------------------------------
# Slot Requirement Class and Properties
# -----------------------------------------------------------------------------

vao:SlotRequirement a owl:Class ;
    rdfs:label "Slot Requirement" ;
    rdfs:comment "Specifies requirements for a slot within a composition pattern." .

vao:slotType a owl:ObjectProperty ;
    rdfs:label "slot type" ;
    rdfs:domain vao:SlotRequirement ;
    rdfs:range vao:SemanticSlot ;
    rdfs:comment "The type of semantic slot required." .

vao:minCount a owl:DatatypeProperty ;
    rdfs:label "minimum count" ;
    rdfs:domain vao:SlotRequirement ;
    rdfs:range xsd:integer ;
    rdfs:comment "Minimum number of this slot type required in the pattern." .

vao:maxCount a owl:DatatypeProperty ;
    rdfs:label "maximum count" ;
    rdfs:domain vao:SlotRequirement ;
    rdfs:range xsd:integer ;
    rdfs:comment "Maximum number of this slot type allowed in the pattern." .

vao:preferredArtifact a owl:ObjectProperty ;
    rdfs:label "preferred artifact" ;
    rdfs:domain vao:SlotRequirement ;
    rdfs:range vao:Artifact ;
    rdfs:comment "Preferred artifact type for this slot in this pattern." .

# -----------------------------------------------------------------------------
# Composition Instance Properties
# -----------------------------------------------------------------------------

vao:CompositionInstance a owl:Class ;
    rdfs:label "Composition Instance" ;
    rdfs:comment "A concrete instantiation of a composition pattern." .

vao:instanceOf a owl:ObjectProperty ;
    rdfs:label "instance of" ;
    rdfs:domain vao:CompositionInstance ;
    rdfs:range vao:CompositionPattern ;
    rdfs:comment "The pattern this composition instance is based on." .

vao:hasSlot a owl:ObjectProperty ;
    rdfs:label "has slot" ;
    rdfs:domain vao:CompositionInstance ;
    rdfs:range vao:SlotInstance ;
    rdfs:comment "A slot instance within this composition." .

vao:SlotInstance a owl:Class ;
    rdfs:label "Slot Instance" ;
    rdfs:comment "A concrete slot within a composition instance." .

vao:slotTypeOf a owl:ObjectProperty ;
    rdfs:label "slot type of" ;
    rdfs:domain vao:SlotInstance ;
    rdfs:range vao:SemanticSlot ;
    rdfs:comment "The semantic slot type of this instance." .

vao:containsArtifact a owl:ObjectProperty ;
    rdfs:label "contains artifact" ;
    rdfs:domain vao:SlotInstance ;
    rdfs:range vao:Artifact ;
    rdfs:comment "An artifact contained in this slot." .

vao:aspectRatioWidth a owl:DatatypeProperty ;
    rdfs:label "aspect ratio width" ;
    rdfs:domain vao:SlotInstance ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Width component of slot aspect ratio." .

vao:aspectRatioHeight a owl:DatatypeProperty ;
    rdfs:label "aspect ratio height" ;
    rdfs:domain vao:SlotInstance ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Height component of slot aspect ratio." .

vao:gridPosition a owl:DatatypeProperty ;
    rdfs:label "grid position" ;
    rdfs:domain vao:SlotInstance ;
    rdfs:range xsd:integer ;
    rdfs:comment "Position in the layout grid (0-100, where 0=top, 100=bottom)." .

# ============================================================================
# END OF ONTOLOGY
# ============================================================================
